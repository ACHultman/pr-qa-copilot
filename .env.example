# PR QA Copilot — local dev helpers
#
# This repo is a GitHub Action. Most configuration is passed as action inputs.
#
# For local Playwright experimentation, you can set a base URL here and run
# the sample Playwright test in ./playwright.

BASE_URL=https://example.com
PATHS=/
VIEWPORT=1280x720

# Optional: enable OpenAI PR summaries in the action (set in GitHub Secrets)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
