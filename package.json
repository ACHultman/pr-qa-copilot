{
  "name": "pr-qa-copilot",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action: PR summary + Playwright screenshot pack + visual diffs",
  "main": "dist/index.js",
  "scripts": {
    "test": "node --test",
    "build": "ncc build src/run.js -o dist --source-map",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('no lint configured')\""
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "openai": "^6.27.0",
    "pixelmatch": "^5.3.0",
    "playwright": "1.55.1",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "@types/node": "^25.4.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.5.4"
  }
}
